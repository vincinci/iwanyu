{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "env": {
    "VITE_API_URL": "https://iwanyu-backend.onrender.com/api",
    "VITE_APP_NAME": "Iwanyu Store",
    "VITE_APP_DESCRIPTION": "Your Premier Ecommerce Destination",
    "VITE_FRONTEND_URL": "https://iwanyu.vercel.app"
  },
  "redirects": [
    {
      "source": "/logo",
      "destination": "/iwanyu-logo.png",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api|_next|_static|assets|favicon.ico|robots.txt|sitemap.xml|manifest.json|sw.js|.*\\.(png|jpg|jpeg|gif|svg|ico|js|css|woff|woff2|ttf|eot|json|xml|txt|webp|wasm)).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/*.(png|jpg|jpeg|gif|svg|ico|js|css|woff|woff2|ttf|eot|webp)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
} 